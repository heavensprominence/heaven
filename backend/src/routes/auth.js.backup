const express = require('express');
const bcrypt = require('bcrypt');
const jwt = require('jsonwebtoken');
const { v4: uuidv4 } = require('uuid');
const router = express.Router();
const db = require('../db');
const { sendVerificationEmail, sendPasswordResetEmail, sendLoginVerificationCode } = require('../services/emailService');

// Helper function to generate device fingerprint
const generateDeviceFingerprint = (req) => {
  const userAgent = req.headers['user-agent'] || '';
  const ip = req.ip || req.connection.remoteAddress || '';
  // Use first 3 octets of IP for privacy (IP range, not exact IP)
  const ipParts = ip.split('.');
  const ipRange = ipParts.slice(0, 3).join('.');
  return Buffer.from(`${userAgent}|${ipRange}`).toString('base64').substring(0, 100);
};

// Helper function to check if 2FA is required
const isTwoFactorRequired = async (userId, deviceFingerprint, req) => {
  // Check if device is trusted
  const deviceResult = await db.query(
    `SELECT last_verified_at FROM trusted_devices 
     WHERE user_id = $1 AND device_fingerprint = $2`,
    [userId, deviceFingerprint]
  );
  
  const now = new Date();
  const oneYearAgo = new Date();
  oneYearAgo.setFullYear(oneYearAgo.getFullYear() - 1);
  
  // Check if mandatory yearly verification is needed
  const userResult = await db.query(
    `SELECT last_mandatory_2fa FROM users WHERE id = $1`,
    [userId]
  );
  
  const lastMandatory2fa = userResult.rows[0]?.last_mandatory_2fa;
  const needsYearlyVerification = !lastMandatory2fa || new Date(lastMandatory2fa) < oneYearAgo;
  
  // If device not trusted OR needs yearly verification
  if (deviceResult.rows.length === 0 || needsYearlyVerification) {
    return { required: true, needsYearlyVerification, deviceTrusted: deviceResult.rows.length > 0 };
  }
  
  // Check if device verification is older than 30 days (optional: re-verify every 30 days)
  const lastVerified = deviceResult.rows[0].last_verified_at;
  const thirtyDaysAgo = new Date();
  thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
  
  if (new Date(lastVerified) < thirtyDaysAgo) {
    return { required: true, needsYearlyVerification: false, deviceTrusted: true };
  }
  
  return { required: false, needsYearlyVerification: false, deviceTrusted: true };
};

// Generate and send 2FA code
const sendTwoFactorCode = async (userId, email, sessionId, req) => {
  // Generate 6-digit code
  const code = Math.floor(100000 + Math.random() * 900000).toString();
  const expiresAt = new Date();
  expiresAt.setMinutes(expiresAt.getMinutes() + 10); // Code expires in 10 minutes
  
  // Store code in database
  await db.query(
    `INSERT INTO login_verification_codes (user_id, code, session_id, expires_at)
     VALUES ($1, $2, $3, $4)`,
    [userId, code, sessionId, expiresAt]
  );
  
  // Send code via email
  await sendLoginVerificationCode(email, code);
  
  return true;
};

// LOGIN endpoint - returns 2FA required or token
router.post('/login', async (req, res) => {
  const { email, password } = req.body;
  
  try {
    // Find user
    const result = await db.query(
      `SELECT id, email, password_hash, is_active, is_suspended, is_super_admin, email_verified 
       FROM users WHERE email = $1`,
      [email]
    );
    
    if (result.rows.length === 0) {
      return res.status(401).json({ error: 'Invalid email or password' });
    }
    
    const user = result.rows[0];
    
    // Check if user is active
    if (!user.is_active) {
      return res.status(401).json({ error: 'Account is deactivated' });
    }
    
    if (user.is_suspended) {
      return res.status(401).json({ error: 'Account is suspended' });
    }
    
    if (!user.email_verified) {
      return res.status(401).json({ error: 'Please verify your email address first' });
    }
    
    // Verify password
    const validPassword = await bcrypt.compare(password, user.password_hash);
    if (!validPassword) {
      return res.status(401).json({ error: 'Invalid email or password' });
    }
    
    // Generate device fingerprint
    const deviceFingerprint = generateDeviceFingerprint(req);
    const sessionId = uuidv4();
    
    // Check if 2FA is required
    const twoFactorCheck = await isTwoFactorRequired(user.id, deviceFingerprint, req);
    
    if (twoFactorCheck.required) {
      // Send 2FA code
      await sendTwoFactorCode(user.id, user.email, sessionId, req);
      
      // Return 2FA required response
      return res.status(200).json({
        requiresTwoFactor: true,
        sessionId: sessionId,
        message: 'Verification code sent to your email',
        deviceTrusted: twoFactorCheck.deviceTrusted,
        needsYearlyVerification: twoFactorCheck.needsYearlyVerification
      });
    }
    
    // No 2FA required - issue token immediately
    const token = jwt.sign(
      {
        id: user.id,
        email: user.email,
        isSuperAdmin: user.is_super_admin === true
      },
      process.env.JWT_SECRET,
      { expiresIn: '7d' }
    );
    
    // Update last_mandatory_2fa if this was the yearly check
    if (twoFactorCheck.needsYearlyVerification) {
      await db.query(
        `UPDATE users SET last_mandatory_2fa = NOW() WHERE id = $1`,
        [user.id]
      );
    }
    
    // Update trusted device
    await db.query(
      `INSERT INTO trusted_devices (user_id, device_fingerprint, user_agent, ip_address, last_verified_at)
       VALUES ($1, $2, $3, $4, NOW())
       ON CONFLICT (user_id, device_fingerprint) 
       DO UPDATE SET last_verified_at = NOW(), user_agent = $3, ip_address = $4`,
      [user.id, deviceFingerprint, req.headers['user-agent'] || '', req.ip || '']
    );
    
    res.json({
      success: true,
      token,
      user: {
        id: user.id,
        email: user.email,
        isSuperAdmin: user.is_super_admin === true
      }
    });
  } catch (error) {
    console.error('Login error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
});

// VERIFY 2FA endpoint
router.post('/verify-2fa', async (req, res) => {
  const { sessionId, code, rememberDevice } = req.body;
  
  try {
    // Find the verification code
    const result = await db.query(
      `SELECT user_id, code, expires_at, verified 
       FROM login_verification_codes 
       WHERE session_id = $1 AND verified = false
       ORDER BY created_at DESC LIMIT 1`,
      [sessionId]
    );
    
    if (result.rows.length === 0) {
      return res.status(401).json({ error: 'Invalid or expired verification session' });
    }
    
    const verification = result.rows[0];
    
    // Check if code is expired
    if (new Date(verification.expires_at) < new Date()) {
      return res.status(401).json({ error: 'Verification code has expired. Please login again.' });
    }
    
    // Verify code
    if (verification.code !== code) {
      return res.status(401).json({ error: 'Invalid verification code' });
    }
    
    // Mark code as verified
    await db.query(
      `UPDATE login_verification_codes SET verified = true WHERE session_id = $1`,
      [sessionId]
    );
    
    // Get user details
    const userResult = await db.query(
      `SELECT id, email, is_super_admin FROM users WHERE id = $1`,
      [verification.user_id]
    );
    
    const user = userResult.rows[0];
    
    // Update last_mandatory_2fa
    await db.query(
      `UPDATE users SET last_mandatory_2fa = NOW() WHERE id = $1`,
      [user.id]
    );
    
    // Generate device fingerprint from request
    const deviceFingerprint = generateDeviceFingerprint(req);
    
    // Trust device if requested
    if (rememberDevice === true) {
      await db.query(
        `INSERT INTO trusted_devices (user_id, device_fingerprint, user_agent, ip_address, last_verified_at)
         VALUES ($1, $2, $3, $4, NOW())
         ON CONFLICT (user_id, device_fingerprint) 
         DO UPDATE SET last_verified_at = NOW(), user_agent = $3, ip_address = $4`,
        [user.id, deviceFingerprint, req.headers['user-agent'] || '', req.ip || '']
      );
    }
    
    // Generate JWT token
    const token = jwt.sign(
      {
        id: user.id,
        email: user.email,
        isSuperAdmin: user.is_super_admin === true
      },
      process.env.JWT_SECRET,
      { expiresIn: '7d' }
    );
    
    res.json({
      success: true,
      token,
      user: {
        id: user.id,
        email: user.email,
        isSuperAdmin: user.is_super_admin === true
      }
    });
  } catch (error) {
    console.error('2FA verification error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
});

// RESEND 2FA code endpoint
router.post('/resend-2fa', async (req, res) => {
  const { sessionId } = req.body;
  
  try {
    // Get the session info
    const result = await db.query(
      `SELECT user_id FROM login_verification_codes 
       WHERE session_id = $1 AND verified = false
       ORDER BY created_at DESC LIMIT 1`,
      [sessionId]
    );
    
    if (result.rows.length === 0) {
      return res.status(401).json({ error: 'Invalid session' });
    }
    
    const userId = result.rows[0].user_id;
    
    // Get user email
    const userResult = await db.query(
      `SELECT email FROM users WHERE id = $1`,
      [userId]
    );
    
    // Generate new code
    const code = Math.floor(100000 + Math.random() * 900000).toString();
    const expiresAt = new Date();
    expiresAt.setMinutes(expiresAt.getMinutes() + 10);
    
    // Store new code
    await db.query(
      `INSERT INTO login_verification_codes (user_id, code, session_id, expires_at)
       VALUES ($1, $2, $3, $4)`,
      [userId, code, sessionId, expiresAt]
    );
    
    // Send code via email
    await sendLoginVerificationCode(userResult.rows[0].email, code);
    
    res.json({ success: true, message: 'Verification code resent' });
  } catch (error) {
    console.error('Resend 2FA error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
});

// GET trusted devices (for user settings page)
router.get('/trusted-devices', verifyToken, async (req, res) => {
  try {
    const result = await db.query(
      `SELECT id, device_fingerprint, user_agent, ip_address, last_verified_at, created_at
       FROM trusted_devices 
       WHERE user_id = $1
       ORDER BY last_verified_at DESC`,
      [req.userId]
    );
    
    res.json({ devices: result.rows });
  } catch (error) {
    console.error('Get trusted devices error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
});

// REMOVE trusted device
router.delete('/trusted-devices/:deviceId', verifyToken, async (req, res) => {
  try {
    await db.query(
      `DELETE FROM trusted_devices WHERE id = $1 AND user_id = $2`,
      [req.params.deviceId, req.userId]
    );
    
    res.json({ success: true });
  } catch (error) {
    console.error('Remove trusted device error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
});

